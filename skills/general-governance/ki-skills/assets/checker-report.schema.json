{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledgeislands.dev/schemas/checker-report/v1.json",
  "title": "Knowledge Islands canonical checker report record",
  "description": "One JSONL record from a governance skill audit or conform run.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "runId", "record", "mode", "concern", "target", "generatedAt"],
  "properties": {
    "version": { "const": 1 },
    "runId": { "type": "string", "format": "uuid" },
    "record": { "enum": ["meta", "finding", "summary"] },
    "mode": { "enum": ["audit", "conform"] },
    "concern": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "type": { "enum": ["M", "J"] },
    "level": { "enum": ["FAIL", "WARN", "POLISH", "ADVISORY", "INFO", "NA", "PASS"] },
    "code": { "type": "string", "minLength": 1 },
    "message": { "type": "string", "minLength": 1 },
    "ref": { "type": "string", "minLength": 1 },
    "file": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fail", "warn", "polish", "advisory", "info", "na", "pass"],
      "properties": {
        "fail": { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 },
        "polish": { "type": "integer", "minimum": 0 },
        "advisory": { "type": "integer", "minimum": 0 },
        "info": { "type": "integer", "minimum": 0 },
        "na": { "type": "integer", "minimum": 0 },
        "pass": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "oneOf": [
    {
      "properties": { "record": { "const": "meta" } },
      "not": { "anyOf": [{ "required": ["type"] }, { "required": ["level"] }, { "required": ["code"] }, { "required": ["message"] }, { "required": ["summary"] }] }
    },
    {
      "required": ["type", "level", "code", "message"],
      "properties": { "record": { "const": "finding" } },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "J" } } },
          "then": { "properties": { "level": { "const": "ADVISORY" } }, "required": ["ref"] }
        }
      ]
    },
    {
      "required": ["summary"],
      "properties": { "record": { "const": "summary" } },
      "not": { "anyOf": [{ "required": ["type"] }, { "required": ["level"] }, { "required": ["code"] }, { "required": ["message"] }] }
    }
  ]
}
