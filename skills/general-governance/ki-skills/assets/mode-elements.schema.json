{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledgeislands.info/schemas/mode-elements/v1.json",
  "title": "Knowledge Islands mode elements",
  "description": "A skill-local declaration of independently schedulable AUDIT or CONFORM work.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "elements"],
  "properties": {
    "version": { "const": 1 },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/element" }
    }
  },
  "$defs": {
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "phase", "entry", "reads", "writes"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "mode": { "enum": ["audit", "conform"] },
        "phase": { "enum": ["prepare", "inspect", "write", "project", "normalise"] },
        "entry": { "type": "string", "pattern": "^scripts/[a-z][a-z0-9-]*\\.ts$" },
        "before": { "type": "array", "items": { "type": "string", "pattern": "^(?:ki-[a-z0-9-]+/)?[a-z][a-z0-9-]*$" }, "uniqueItems": true },
        "after": { "type": "array", "items": { "type": "string", "pattern": "^(?:ki-[a-z0-9-]+/)?[a-z][a-z0-9-]*$" }, "uniqueItems": true },
        "reads": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "writes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    }
  }
}
