# Dependency directories
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json

# OS specific files
.DS_Store
Thumbs.db

# Logs
logs
*.log
*.tsbuildinfo

# Eval outputs — regeneratable run results (the harness + scenarios are the source
# of truth; the live summary lives in evals/README.md). Re-run with `bun run eval`.
evals/results/

# KI governance working artifacts — derived audit/conform reports (regenerated each
# run via a checker's --report). The .ki-meta/ namespace itself is left tracked so a
# future durable artifact can be committed; only these derived subdirs are ignored.
.ki-meta/audits/
.ki-meta/conform/

# Project-local skills and agents are generated by ki-bootstrap, not committed.
# ki-self is the one committed repository-local skill, carried as a regular identical
# payload for every declared runtime.
.claude/skills/*
!.claude/skills/ki-self/
!.claude/skills/ki-self/SKILL.md
.claude/agents/

# Generated project-local links (ki-bootstrap) — never committed
.agents/skills/*
!.agents/skills/ki-self/
!.agents/skills/ki-self/SKILL.md
