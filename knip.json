{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["skills/*/scripts/*.ts", "scripts/*.ts", "evals/harness.ts", "evals/guide-suite.ts", ".claude/workflows/*.ts"],
  "project": ["skills/*/scripts/**/*.ts", "scripts/**/*.ts", "evals/**/*.ts", ".claude/workflows/**/*.ts"],
  "ignore": [".ki/bootstrap/**", ".ki/bin/**", "src/generated/**", ".claude/skills/**", ".claude/agents/**", ".agents/skills/**"],
  "ignoreBinaries": ["claude", "gh"],
  "ignoreDependencies": ["syncpack"],
  "ignoreExportsUsedInFile": true
}
