{
  "name": "@knowledgeislands/arcadia-agentic-harness",
  "description": "Reusable Agent Skills for the Arcadia / Knowledge Islands work, installed into a Claude skills directory by symlink.",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bugs": {
    "url": "https://github.com/knowledgeislands/arcadia-agentic-harness/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "syncpack": "^15.3.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/arcadia-agentic-harness#readme",
  "keywords": [
    "agent-skills",
    "anthropic",
    "claude",
    "claude-code",
    "knowledge-islands",
    "skills"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/arcadia-agentic-harness.git"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "deps:missing": "bunx depcheck --json | bunx node-jq --sort-keys '.' | bunx node-jq '.missing | keys | .[]' | xargs bun add -D",
    "deps:unused": "bunx depcheck --json | bunx node-jq --sort-keys '.' | bunx node-jq '.devDependencies[]' | xargs bun remove",
    "deps:update": "bun update --latest",
    "engineering:audit": "bun skills/knowledgeislands-engineering/scripts/audit-engineering.ts",
    "eval": "bun evals/harness.ts",
    "kb:audit": "bun skills/knowledgeislands-kb/scripts/audit-kb.ts",
    "lint:check": "bunx @biomejs/biome check",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe",
    "lint:format": "bunx @biomejs/biome format --write",
    "lint:md": "bunx prettier --write \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "lint:md:check": "bunx prettier --check \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "lint:package": "bunx syncpack format",
    "lint:types": "tsc --noEmit",
    "prepare": "husky",
    "repo:audit": "bun skills/knowledgeislands-repo/scripts/audit-repo.ts",
    "skills:link": "bun scripts/sync-skills.ts link",
    "skills:lint": "bun skills/knowledgeislands-skills/scripts/lint-skills.ts skills",
    "skills:status": "bun scripts/sync-skills.ts status",
    "skills:unlink": "bun scripts/sync-skills.ts unlink",
    "streams:audit": "bun skills/knowledgeislands-streams/scripts/audit-streams.ts",
    "tokenomics:audit": "bun skills/knowledgeislands-tokenomics/scripts/audit-tokenomics.ts"
  },
  "type": "module"
}
