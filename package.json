{
  "name": "@knowledgeislands/arcadia-agentic-harness",
  "description": "Knowledge Islands agentic harness — canonical home for Agent Skills, Agents, MCP servers, and Evals across the Knowledge Islands ecosystem.",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bugs": {
    "url": "https://github.com/knowledgeislands/arcadia-agentic-harness/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.9.4",
    "syncpack": "^15.3.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/arcadia-agentic-harness#readme",
  "keywords": [
    "agent-skills",
    "anthropic",
    "claude",
    "claude-code",
    "knowledge-islands",
    "skills"
  ],
  "license": "UNLICENSED",
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/arcadia-agentic-harness.git"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "ki:activities:audit": "bun skills/knowledgeislands-activities/scripts/audit-activities.ts",
    "ki:agents:lint": "bun skills/knowledgeislands-agents/scripts/lint-agents.ts agents",
    "ki:authoring:audit": "bun skills/knowledgeislands-authoring/scripts/audit-authoring.ts",
    "ki:codegen": "bun scripts/generate-clients.ts",
    "ki:conform": "bun run ki:deps:update && bun run ki:lint:package && bun run ki:lint:format && bun run ki:lint:fix && bun run ki:lint:md",
    "ki:decision-records:audit": "bun skills/knowledgeislands-decision-records/scripts/audit-drs.ts",
    "ki:deps:check": "bunx knip --dependencies --no-config-hints",
    "ki:deps:fix": "bunx knip --dependencies --fix --no-config-hints",
    "ki:deps:update": "bun update --latest",
    "ki:engineering:audit": "bun skills/knowledgeislands-engineering/scripts/audit-engineering.ts",
    "ki:eval": "bun evals/harness.ts",
    "ki:harness:audit": "bun skills/knowledgeislands-harness/scripts/audit-harness.ts",
    "ki:hosting:audit": "bun skills/knowledgeislands-cloudflare-hosting/scripts/audit-cloudflare-hosting.ts",
    "ki:kb:audit": "bun skills/knowledgeislands-kb/scripts/audit-kb.ts",
    "ki:knip": "bunx knip --no-config-hints",
    "ki:lint:check": "bunx @biomejs/biome check",
    "ki:lint:fix": "bunx @biomejs/biome check --write --unsafe",
    "ki:lint:format": "bunx @biomejs/biome format --write",
    "ki:lint:md": "bunx prettier --write \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "ki:lint:md:check": "bunx prettier --check \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "ki:lint:package": "bunx syncpack format",
    "ki:lint:types": "tsc --noEmit",
    "ki:live-artifacts:audit": "bun skills/knowledgeislands-live-artifacts/scripts/audit-live-artifacts.ts",
    "ki:mcp:audit": "bun skills/knowledgeislands-mcp/scripts/audit-mcp.ts",
    "ki:repo:audit": "bun skills/knowledgeislands-repo/scripts/audit-repo.ts",
    "ki:skills:link:global": "bun scripts/sync-skills.ts link --only knowledgeislands-bootstrap",
    "ki:skills:link:project": "bun skills/knowledgeislands-bootstrap/scripts/link-skills.ts --all",
    "ki:skills:lint": "bun skills/knowledgeislands-skills/scripts/lint-skills.ts skills",
    "ki:skills:refresh-status": "bun skills/knowledgeislands-skills/scripts/lint-skills.ts skills --refresh-status",
    "ki:skills:status": "bun scripts/sync-skills.ts status",
    "ki:skills:unlink": "bun scripts/sync-skills.ts unlink",
    "ki:streams:audit": "bun skills/knowledgeislands-streams/scripts/audit-streams.ts",
    "ki:tokenomics:audit": "bun skills/knowledgeislands-tokenomics/scripts/audit-tokenomics.ts",
    "ki:verify": "bun run ki:lint:check && bun run ki:lint:types && bun run ki:lint:md:check && bun run ki:knip",
    "ki:websites:audit": "bun skills/knowledgeislands-11ty-websites/scripts/audit-websites.ts",
    "prepare": "husky"
  },
  "type": "module"
}
