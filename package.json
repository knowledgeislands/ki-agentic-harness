{
  "name": "@knowledgeislands/ki-agentic-harness",
  "description": "Knowledge Islands agentic harness — canonical home for Agent Skills, Agents, MCP servers, and Evals across the Knowledge Islands ecosystem.",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bin": {
    "ki-bootstrap": "skills/keystone/ki-bootstrap/scripts/internal/repo-bootstrap/repo-bootstrap.ts"
  },
  "bugs": {
    "url": "https://github.com/knowledgeislands/ki-agentic-harness/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.5",
    "syncpack": "^15.3.2",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/ki-agentic-harness#readme",
  "keywords": [
    "agent-skills",
    "anthropic",
    "claude",
    "claude-code",
    "knowledge-islands",
    "multi-runtime",
    "skills"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2 --no-globs"
    ]
  },
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/ki-agentic-harness.git"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "ki:agents:audit": "bun .ki/bin/aggregate.ts audit --skill ki-agents",
    "ki:agents:conform": "bun .ki/bin/aggregate.ts conform --skill ki-agents",
    "ki:audit": "bun .ki/bin/aggregate.ts audit",
    "ki:authoring:audit": "bun .ki/bin/aggregate.ts audit --skill ki-authoring",
    "ki:authoring:conform": "bun .ki/bin/aggregate.ts conform --skill ki-authoring",
    "ki:binding:build-plugin": "bun skills/environment/ki-binding/scripts/build-plugin.ts",
    "ki:bootstrap:audit": "bun skills/keystone/ki-bootstrap/scripts/govern.ts audit .",
    "ki:bootstrap:conform": "bun skills/keystone/ki-bootstrap/scripts/govern.ts conform .",
    "ki:conform": "bun .ki/bin/aggregate.ts conform",
    "ki:decision-records:audit": "bun .ki/bin/aggregate.ts audit --skill ki-decision-records",
    "ki:decision-records:conform": "bun .ki/bin/aggregate.ts conform --skill ki-decision-records",
    "ki:educate": "bun .ki/bin/aggregate.ts educate",
    "ki:engineering:audit": "bun .ki/bin/aggregate.ts audit --skill ki-engineering",
    "ki:engineering:conform": "bun .ki/bin/aggregate.ts conform --skill ki-engineering",
    "ki:eval": "bun evals/harness.ts",
    "ki:feature-definitions:audit": "bun .ki/bin/aggregate.ts audit --skill ki-feature-definitions",
    "ki:feature-definitions:conform": "bun .ki/bin/aggregate.ts conform --skill ki-feature-definitions",
    "ki:handoffs:audit": "bun .ki/bin/aggregate.ts audit --skill ki-handoffs",
    "ki:handoffs:conform": "bun .ki/bin/aggregate.ts conform --skill ki-handoffs",
    "ki:harness:audit": "bun .ki/bin/aggregate.ts audit --skill ki-harness",
    "ki:harness:conform": "bun .ki/bin/aggregate.ts conform --skill ki-harness",
    "ki:help": "bun .ki/bin/aggregate.ts help",
    "ki:housekeeping:audit": "bun .ki/bin/aggregate.ts audit --skill ki-housekeeping",
    "ki:housekeeping:conform": "bun .ki/bin/aggregate.ts conform --skill ki-housekeeping",
    "ki:repo-roadmap:audit": "bun .ki/bin/aggregate.ts audit --skill ki-repo-roadmap",
    "ki:repo-roadmap:conform": "bun .ki/bin/aggregate.ts conform --skill ki-repo-roadmap",
    "ki:repo:audit": "bun .ki/bin/aggregate.ts audit --skill ki-repo",
    "ki:repo:conform": "bun .ki/bin/aggregate.ts conform --skill ki-repo",
    "ki:skills:audit": "bun .ki/bin/aggregate.ts audit --skill ki-skills",
    "ki:skills:conform": "bun .ki/bin/aggregate.ts conform --skill ki-skills",
    "ki:skills:copy:project": "bun skills/keystone/ki-bootstrap/scripts/internal/repo-bootstrap/publish-project-skills.ts",
    "ki:skills:graph": "bun .ki/bin/skill-graph.ts --tree",
    "ki:skills:help": "bun .ki/bin/skill-help.ts",
    "ki:skills:link:global": "bun skills/repo-structure/ki-harness/scripts/link-global-skills.ts",
    "ki:skills:refresh-status": "bun skills/keystone/ki-skills/scripts/govern.ts audit skills --refresh-status",
    "ki:tokenomics:audit": "bun .ki/bin/aggregate.ts audit --skill ki-tokenomics",
    "ki:tokenomics:conform": "bun .ki/bin/aggregate.ts conform --skill ki-tokenomics",
    "prepare": "husky",
    "test": "bun test --isolate --max-concurrency=1 ./skills ./hooks && bun evals/guide-suite.ts && bun skills/keystone/ki-bootstrap/scripts/internal/repo-bootstrap/skill-graph.ts --check --check-doc docs/guides/user-guide/skills.md && bun skills/keystone/ki-bootstrap/scripts/internal/repo-bootstrap/skill-help.ts --check && bun skills/keystone/ki-bootstrap/scripts/govern.ts audit ."
  },
  "type": "module"
}
