{
  "name": "@knowledgeislands/ki-agentic-harness",
  "description": "Knowledge Islands agentic harness — canonical home for Agent Skills, Agents, MCP servers, and Evals across the Knowledge Islands ecosystem.",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bugs": {
    "url": "https://github.com/knowledgeislands/ki-agentic-harness/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "knip": "^6.25.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.4",
    "syncpack": "^15.3.2",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/ki-agentic-harness#readme",
  "keywords": [
    "agent-skills",
    "anthropic",
    "claude",
    "claude-code",
    "knowledge-islands",
    "skills"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/ki-agentic-harness.git"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "ki:agents:audit": "bun scripts/ki/ki-agents/lint-agents.ts .",
    "ki:agents:link:project": "bun .claude/skills/ki-bootstrap/scripts/link-agents.ts .",
    "ki:agents:lint": "bun skills/ki-agents/scripts/lint-agents.ts agents",
    "ki:audit": "bun scripts/ki/aggregate.ts audit",
    "ki:authoring:audit": "bun skills/ki-authoring/scripts/audit-authoring.ts",
    "ki:binding:audit": "bun skills/ki-binding/scripts/audit-binding.ts",
    "ki:binding:build-plugin": "bun skills/ki-binding/scripts/build-plugin.ts",
    "ki:binding:conform": "bun .claude/skills/ki-binding/scripts/conform-cowork.ts .",
    "ki:bootstrap:test": "bun skills/ki-bootstrap/scripts/link-skills.test.ts",
    "ki:codegen": "bun scripts/generate-clients.ts",
    "ki:conform": "bun run ki:deps:refresh && bun run ki:lint:package && bun run ki:lint:format && bun run ki:lint:fix && bun run ki:lint:md",
    "ki:decision-records:audit": "bun skills/ki-decision-records/scripts/audit-drs.ts",
    "ki:deps:check": "bunx knip --dependencies --no-config-hints",
    "ki:deps:fix": "bunx knip --dependencies --fix --no-config-hints",
    "ki:deps:refresh": "bun update --force",
    "ki:deps:update": "bun update --latest && bun install",
    "ki:engineering:audit": "bun skills/ki-engineering/scripts/audit-engineering.ts",
    "ki:eval": "bun evals/harness.ts",
    "ki:feature-definitions:audit": "bun skills/ki-feature-definitions/scripts/audit-features.ts",
    "ki:guide:test": "bun evals/guide-suite.ts",
    "ki:handoffs:audit": "bun skills/ki-handoffs/scripts/audit-handoffs.ts",
    "ki:harness:audit": "bun skills/ki-harness/scripts/audit-harness.ts",
    "ki:homebrew-tap:audit": "bun skills/ki-homebrew-tap/scripts/audit-homebrew-tap.ts",
    "ki:housekeeping:audit": "bun skills/ki-housekeeping/scripts/audit-memory.ts",
    "ki:init": "bun scripts/ki/aggregate.ts init",
    "ki:kb-activities:audit": "bun skills/ki-kb-activities/scripts/audit-activities.ts",
    "ki:kb-live-artifacts:audit": "bun skills/ki-kb-live-artifacts/scripts/audit-live-artifacts.ts",
    "ki:kb-streams:audit": "bun skills/ki-kb-streams/scripts/audit-streams.ts",
    "ki:kb:audit": "bun skills/ki-kb/scripts/audit-kb.ts",
    "ki:knip": "bunx knip --no-config-hints",
    "ki:lint:check": "bunx @biomejs/biome check",
    "ki:lint:fix": "bunx @biomejs/biome check --write --unsafe",
    "ki:lint:format": "bunx @biomejs/biome format --write",
    "ki:lint:md": "bunx prettier --write \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "ki:lint:md:check": "bunx prettier --check \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "ki:lint:package": "bunx syncpack format",
    "ki:lint:types": "tsc --noEmit",
    "ki:mcp:audit": "bun skills/ki-mcp/scripts/audit-mcp.ts",
    "ki:plans:audit": "bun skills/ki-plans/scripts/audit-plans.ts",
    "ki:plugins:audit": "bun skills/ki-plugins/scripts/audit-plugins.ts",
    "ki:repo:audit": "bun skills/ki-repo/scripts/audit-repo.ts",
    "ki:repo:conform": "bun .claude/skills/ki-repo/scripts/conform-repo.ts .",
    "ki:skills:audit": "bun scripts/ki/ki-skills/lint-skills.ts .",
    "ki:skills:graph": "bun scripts/skill-graph.ts --tree",
    "ki:skills:graph:check": "bun scripts/skill-graph.ts --check",
    "ki:skills:link:global": "bun scripts/sync-skills.ts link --only ki-bootstrap",
    "ki:skills:link:project": "bun skills/ki-bootstrap/scripts/link-skills.ts --all",
    "ki:skills:lint": "bun skills/ki-skills/scripts/lint-skills.ts skills",
    "ki:skills:refresh-status": "bun skills/ki-skills/scripts/lint-skills.ts skills --refresh-status",
    "ki:skills:status": "bun scripts/sync-skills.ts status",
    "ki:skills:unlink": "bun scripts/sync-skills.ts unlink",
    "ki:tokenomics:audit": "bun skills/ki-tokenomics/scripts/audit-tokenomics.ts",
    "ki:tools:audit": "bun skills/ki-tools/scripts/audit-tools.ts",
    "ki:verify": "bun run ki:lint:check && bun run ki:lint:types && bun run ki:lint:md:check && bun run ki:knip && bun run ki:skills:graph:check && bun run ki:bootstrap:test && bun run ki:guide:test",
    "ki:website-cloudflare:audit": "bun skills/ki-website-cloudflare/scripts/audit-cloudflare-hosting.ts",
    "ki:website:audit": "bun skills/ki-website/scripts/audit-websites.ts",
    "prepare": "husky"
  },
  "type": "module"
}
