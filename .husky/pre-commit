bunx lint-staged || exit 1

# Governance audits: nothing else runs them locally, so validate each artifact
# set when it is staged (added/copied/modified/renamed) — a failure blocks the
# commit. The heavier, GitHub-gated repo/harness audits run in CI, not here.
staged() { git diff --cached --name-only --diff-filter=ACMRD; }

bootstrap_audit_staged() {
  snapshot="$(mktemp -d)" || return 1
  trap 'rm -rf "$snapshot"' EXIT HUP INT TERM
  git checkout-index --all --prefix="$snapshot/" || return 1
  bun "$snapshot/skills/keystone/ki-bootstrap/scripts/audit.ts" "$snapshot"
  status=$?
  rm -rf "$snapshot"
  trap - EXIT HUP INT TERM
  return "$status"
}

if staged | grep -q '^docs/decisions/'; then bun run ki:decision-records:audit || exit 1; fi
if staged | grep -q '^skills/'; then bun run ki:skills:audit || exit 1; fi
if staged | grep -Eq '^(skills/|\.ki-meta/skills/)'; then bootstrap_audit_staged || exit 1; fi
if staged | grep -q '^agents/'; then bun run ki:agents:audit || exit 1; fi
